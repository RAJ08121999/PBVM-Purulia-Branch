# Environment Variables — PBVM Purulia Backend
# Copy this file to .env and fill in your values

# =====================
# Server
# =====================
PORT=5000
NODE_ENV=development

# =====================
# MongoDB
# =====================
MONGODB_URI=mongodb+srv://rajmd1800_db_user:vM9DoZBLb9Ga1EeL@cluster0.oxa4xpx.mongodb.net/?appName=Cluster0
# =====================
# JWT Auth
# =====================
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_here_min_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# =====================
# Cloudinary (File Storage)
# =====================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# =====================
# Email (SMTP / Nodemailer)
# =====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
ADMIN_EMAIL=pbvmpurulia@gmail.com
FROM_EMAIL="PBVM Purulia <noreply@pbvmpurulia.org>"

# =====================
# Frontend URL (for CORS)
# =====================
FRONTEND_URL=http://localhost:3000
